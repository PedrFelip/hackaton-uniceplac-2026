---
import BackgroundEffects from './BackgroundEffects.astro';
import Button from './Button.astro';
---

<section class="hero">
  <div class="hero-bg">
    <BackgroundEffects variant="blobs" opacity="0.35" />
  </div>
  <div class="hero-inner">
    <div class="hero-text">
      <p class="hero-eyebrow">Apresentando</p>
      <h1>
        Conheça o que<br />
        você <em>consome</em>
      </h1>
      <p class="hero-subtitle">
        Escaneie o código de barras de qualquer alimento e descubra<br
          class="hide-mobile"
        />
        instantaneamente se ele é a melhor escolha para você.
      </p>
      <div class="hero-cta-group">
        <Button href="#solucao" variant="primary">Ver como funciona</Button>
        <Button href="#problema" variant="ghost">Entender o problema</Button>
      </div>
      <a href="/downloads/nutriscan.apk" download class="hero-download-badge">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
          <polyline points="7 10 12 15 17 10"></polyline>
          <line x1="12" y1="15" x2="12" y2="3"></line>
        </svg>
        <span>Baixe o app agora</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </a>
    </div>
    <div class="hero-visual">
      <div class="hero-screenshot">
        <img
          src="/screenshots/hero.jpeg"
          alt="NutriScan app"
          width="280"
          height="560"
        />
      </div>
    </div>
  </div>
  <div class="hero-scroll-hint">
    <div class="scroll-line"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .hero-inner {
    position: relative;
    max-width: 1120px;
    margin: 0 auto;
    padding: 120px 24px 80px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .hero-text {
    animation: fadeUp 1s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  }

  .hero-eyebrow {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--green-500);
    margin: 0 0 16px;
  }

  .hero h1 {
    font-size: clamp(2.8rem, 5vw, 4.2rem);
    color: var(--green-900);
    margin: 0 0 24px;
    letter-spacing: -0.02em;
  }

  .hero h1 em {
    font-style: italic;
    color: var(--green-600);
  }

  .hero-subtitle {
    font-size: 1.15rem;
    line-height: 1.8;
    color: var(--text-muted);
    margin: 0 0 40px;
    max-width: 480px;
  }

  .hide-mobile {
    display: inline;
  }

  .hero-cta-group {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .hero-download-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 20px;
    padding: 14px 28px;
    background: linear-gradient(135deg, var(--green-700), var(--green-800));
    color: var(--cream);
    border-radius: 12px;
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    box-shadow: 0 4px 20px rgba(58, 83, 44, 0.3);
    transition: all 0.3s ease;
    animation: fadeUp 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) 0.6s both;
  }

  .hero-download-badge:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(58, 83, 44, 0.4);
  }

  .hero-download-badge svg {
    flex-shrink: 0;
  }

  .hero-download-badge span {
    white-space: nowrap;
  }

  .hero-visual {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    animation: fadeUp 1s cubic-bezier(0.25, 0.46, 0.45, 0.94) 0.2s both;
  }

  .hero-screenshot {
    position: relative;
    z-index: 2;
    border-radius: 28px;
    overflow: hidden;
    box-shadow:
      0 4px 6px rgba(0, 0, 0, 0.05),
      0 20px 60px rgba(39, 55, 31, 0.2);
    border: 6px solid var(--green-900);
  }

  .hero-screenshot img {
    display: block;
    width: 280px;
    height: auto;
  }

  .hero-scroll-hint {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    animation: fadeIn 1s 1.5s both;
  }

  .scroll-line {
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, var(--green-400), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @media (min-width: 1440px) {
    .hero-inner {
      max-width: 1240px;
      gap: 80px;
    }
  }

  @media (max-width: 1024px) {
    .hero-inner {
      gap: 40px;
      padding-left: 24px;
      padding-right: 24px;
    }
  }

  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 40px;
      padding: 100px 20px 48px;
    }

    .hero-subtitle {
      margin-left: auto;
      margin-right: auto;
      font-size: 1rem;
      line-height: 1.7;
    }

    .hide-mobile {
      display: none;
    }

    .hero-cta-group {
      justify-content: center;
    }

    .hero-download-badge {
      justify-content: center;
      width: 100%;
      max-width: 320px;
      margin-left: auto;
      margin-right: auto;
    }

    .hero-visual {
      order: -1;
    }

    .hero-screenshot img {
      width: 220px;
    }

    .hero-screenshot {
      border-radius: 24px;
      border-width: 5px;
    }

    .hero-scroll-hint {
      bottom: 16px;
    }

    .hero h1 {
      font-size: clamp(2rem, 7vw, 2.8rem);
    }
  }

  @media (max-width: 480px) {
    .hero-inner {
      padding: 90px 16px 36px;
      gap: 28px;
    }

    .hero h1 {
      font-size: clamp(1.75rem, 7vw, 2.2rem);
    }

    .hero-subtitle {
      font-size: 0.9rem;
      line-height: 1.65;
    }

    .hero-eyebrow {
      font-size: 0.72rem;
    }

    .hero-cta-group {
      flex-direction: column;
      width: 100%;
      gap: 10px;
    }

    .hero-download-badge {
      max-width: 100%;
      font-size: 0.88rem;
      padding: 12px 20px;
      border-radius: 12px;
    }

    .hero-screenshot img {
      width: 180px;
    }

    .hero-screenshot {
      border-radius: 20px;
      border-width: 4px;
    }
  }
</style>
